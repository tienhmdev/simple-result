{
    "name": "@tienhmdev/simple-result",
    "description": "A lightweight, type-safe Result type for TypeScript — handle success and failure without exceptions.",
    "author": "Hoang Tien (tienhmdev)",
    "version": "1.0.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist/"
    ],
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tienhmdev/simple-result.git"
    },
    "homepage": "https://github.com/tienhmdev/simple-result#readme",
    "bugs": {
        "url": "https://github.com/tienhmdev/simple-result/issues"
    },
    "license": "MIT",
    "keywords": [
        "typescript",
        "result",
        "error-handling",
        "functional",
        "type-safe",
        "ok",
        "err"
    ],
    "devDependencies": {
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@semantic-release/npm": "^13.1.5",
        "@semantic-release/release-notes-generator": "^14.1.0",
        "dts-bundle-generator": "^9.5.1",
        "esbuild": "^0.27.3",
        "prettier": "^3.5.0",
        "rimraf": "^6.1.3",
        "semantic-release": "^25.0.3",
        "typescript": "^5.7.0"
    },
    "scripts": {
        "build": "npm run build:clean && npm run build:esm && npm run build:cjs && npm run build:types",
        "build:clean": "rimraf ./dist",
        "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js",
        "build:cjs": "esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.cjs",
        "build:types": "dts-bundle-generator --export-referenced-types --project tsconfig.json -o dist/index.d.ts src/index.ts && cp dist/index.d.ts dist/index.d.cts",
        "prepublishOnly": "npm run build",
        "release": "semantic-release",
        "fix": "pnpm fix:prettier",
        "fix:prettier": "prettier --write .",
        "lint": "eslint ."
    },
    "engines": {
        "node": ">= 18"
    }
}
